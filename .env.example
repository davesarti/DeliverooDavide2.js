# Esempio di file .env per questo progetto
# Copia questo file in ".env" e sostituisci i placeholder con i valori reali.
# Non committare mai il file .env contenente chiavi reali.

# Configurazione LLM
LITELLM_API_KEY=your_api_key_here
LITELLM_BASE_URL=https://llm.example.com/v1
LOCAL_MODEL=gemma-4-26b

# Connessione al server Deliveroo locale
HOST=http://localhost:8080

# Token per i due agenti (sostituire con i token reali)
TOKEN_BDI=your_bdi_token_here
TOKEN_LLM=your_llm_token_here
