# LLM configuration
LITELLM_API_KEY="your_litelmm_api_key_here"
LITELLM_BASE_URL=https://llm.example.com/v1
LOCAL_MODEL=gemma-4-26b

# Deliveroo local server connection
HOST="http://localhost:8080"

# Agent mode: BDI (BDI only) | LLM (LLM only) | MULTI (BDI + LLM paired, default)
AGENT_MODE="MULTI"

# Number of instances to launch (default: all available token pairs)
AGENT_COUNT=1

# Tokens: use indexed pairs for multiple instances (TOKEN_BDI_1/TOKEN_LLM_1, etc.)
TOKEN_BDI_1="your_bdi_token_1_here"
TOKEN_LLM_1="your_llm_token_1_here"
# Add more pairs if you want extra instances:
# TOKEN_BDI_2="your_bdi_token_2_here"
# TOKEN_LLM_2="your_llm_token_2_here"